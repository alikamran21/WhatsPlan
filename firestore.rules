rules_version = '2';

// ──────────────────────────────────────────────────────────────────────
// WhatsPlan reaches Firestore ONLY through its backend, which uses the
// Firebase Admin SDK. The Admin SDK runs with full privileges and BYPASSES
// these rules entirely — so the backend keeps working no matter what is set
// here. No browser/client ever talks to Firestore directly (the frontend
// goes through the backend REST API), therefore the safest posture is to
// deny ALL direct client access. If anyone gets your public web config and
// tries to read/write Firestore from a browser, they get nothing.
//
// Deploy:  firebase deploy --only firestore:rules
// or paste into: Firebase Console → Firestore Database → Rules → Publish
// ──────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
