PORT=5001
# DEV=true prints/returns the code so you can test without email. Set to
# false in production so codes only go to the inbox.
DEV=true

# Real email (optional in dev). Example with Gmail app password / any SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WhatsPlan <no-reply@whatsplan.local>
