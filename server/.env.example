# ── Server ────────────────────────────────────────────────────────────
PORT=4000
# Allowed frontend origin(s), comma-separated. Leave blank to reflect any
# origin (handy in local dev; lock this down in production).
CORS_ORIGIN=

# ── AI classifier (powers the AI sorter) ──────────────────────────────
# Groq — free, fast, no billing, works in most regions. Recommended.
# Key: https://console.groq.com → API Keys
# Leave GROQ_API_KEY blank to use the built-in heuristic (keyword) classifier
# so the server works with no key while you develop.
GROQ_API_KEY=
# 70b sorts informal/typo'd messages best; 8b-instant is faster + higher limits.
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email OTP via Brevo ───────────────────────────────────────────────
# Turning AI reading ON for a chat requires a verified email, sent to the
# address on the user's profile. Brevo (https://www.brevo.com) is free and
# delivers to any recipient with a verified sender — no domain, no SMTP.
# Leave BREVO_API_KEY blank and the 6-digit code is logged to the console AND
# returned in the API response (devEcho), so you can test with no account.
BREVO_API_KEY=
# Must be a VERIFIED sender in your Brevo account (Senders → Add a sender).
EMAIL_FROM=WhatsPlan <noreply@example.com>
# Minutes the emailed code stays valid (before you enter it).
OTP_TTL_MINUTES=10
# Seconds a successful verification stays valid. After this, turning AI reading
# ON requires doing the OTP again. Default 30.
VERIFY_WINDOW_SECONDS=30
# Force-echo the code in API responses. Defaults to ON when no key is set,
# OFF when BREVO_API_KEY is configured. Set "false" to never echo (prod).
# OTP_DEV_ECHO=false

# ── WhatsApp ──────────────────────────────────────────────────────────
# Only watch these chats (partial, case-insensitive names or exact ids) — works
# for groups and 1-on-1 chats. Blank = ALL. Discover names after linking:
#   GET /api/groups.  Example: WATCH_CHATS=Project Alpha, Family Trip
WATCH_CHATS=
# Show 1-on-1 (direct) chats too, not just groups. "false" = groups only.
WATCH_DMS=true

# Set to "true" to also classify your own outgoing messages.
CLASSIFY_OWN=false

# Ban-safety: "true" makes the link READ-ONLY — the backend will never send a
# WhatsApp message. Automated sending is the main cause of bans.
READ_ONLY=true

# Delete raw chat messages this many hours after the AI reads them (the
# extracted meetings/tasks/announcements are kept). Set to 0 to disable.
RETENTION_HOURS=24

# ── Docker only ───────────────────────────────────────────────────────
# Path to Chromium. In Docker this is set by docker-compose.yml. Leave UNSET
# when running with `npm run dev` outside Docker (puppeteer uses its own browser).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
