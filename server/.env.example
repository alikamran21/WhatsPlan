# ── Server ────────────────────────────────────────────────────────────
PORT=4000
# Allowed frontend origin(s), comma-separated. Leave blank to reflect any
# origin (handy in local dev; lock this down in production).
CORS_ORIGIN=

# ── Gemini (message classifier) ───────────────────────────────────────
# Leave GEMINI_API_KEY blank to run the built-in heuristic classifier
# (keyword/regex based) so the server works with no key while you develop.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# gemini-2.0-flash is GA + free-tier. (gemini-1.5-flash is being retired.)
GEMINI_MODEL=gemini-2.0-flash

# ── Firebase Firestore (storage) ──────────────────────────────────────
# Leave BOTH blank to use the local file store at data/store.json.
# To use Firestore: create a Firebase project, generate a service-account
# key (Project settings → Service accounts → Generate new private key),
# save the JSON somewhere, and point GOOGLE_APPLICATION_CREDENTIALS at it.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ── WhatsApp ──────────────────────────────────────────────────────────
# RECOMMENDED: list only the groups you want to watch so the app never
# touches the rest of your chats. Comma-separated group names (partial,
# case-insensitive) or exact chat ids. Blank = watch ALL group chats.
#   Discover your exact group names/ids after linking:  GET /api/groups
# Example:  WATCH_CHATS=Project Alpha, Family Trip
# Matches both groups and 1-on-1 chats.
WATCH_CHATS=

# Show 1-on-1 (direct) chats too, not just groups. "false" = groups only.
# Ignored when WATCH_CHATS is set (that list already covers both).
WATCH_DMS=true

# Set to "true" to also classify your own outgoing messages.
CLASSIFY_OWN=false

# Ban-safety: "true" makes the link READ-ONLY — the backend will never send a
# WhatsApp message. Automated sending is the main cause of bans, so leaving
# this on while you test is the safest choice.
READ_ONLY=true

# Delete raw chat messages this many hours after the AI reads them (the
# extracted meetings/tasks/announcements are kept). Set to 0 to disable.
RETENTION_HOURS=24

# ── Email OTP ─────────────────────────────────────────────────────────
# Turning AI reading ON for a chat requires a verified email, sent to the
# address on the user's profile. Third-party HTTP APIs — no SMTP, no Google.
# OPTIONAL: leave the chosen provider's key blank and the 6-digit code is logged
# to the console AND returned in the API response (devEcho), so you can test
# with no account. Pick a provider and set its key:
#   resend   — easiest; onboarding@resend.dev only reaches your own Resend
#              account email. Verify a domain to email any address.
#   brevo    — emails ANY recipient with just a verified sender (no domain).
#   sendgrid — emails anywhere; needs single-sender verification.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# BREVO_API_KEY=
# SENDGRID_API_KEY=
# From address. For brevo/sendgrid this must be your verified sender.
EMAIL_FROM=WhatsPlan <onboarding@resend.dev>
# Minutes the emailed code stays valid (before you enter it).
OTP_TTL_MINUTES=10
# Seconds a successful verification stays valid. After this, turning AI reading
# ON requires doing the OTP again. Default 30.
VERIFY_WINDOW_SECONDS=30
# Force-echo the code in API responses. Defaults to ON when no key is set,
# OFF when RESEND_API_KEY is configured. Set "false" to never echo (prod).
# OTP_DEV_ECHO=false

# ── Docker only ───────────────────────────────────────────────────────
# Path to Chromium. In Docker this is set by docker-compose.yml to the
# system Chromium. Leave UNSET when running with `npm run dev` outside Docker
# (puppeteer uses its own downloaded browser). Do NOT set it to an empty
# value in this file — an empty value overrides the Docker default.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
